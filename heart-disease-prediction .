   "source": [
    "def cap_ouliers_iqr(data,column):\n",
    "    Q1=data[column].quantile(0.25)\n",
    "    Q3=data[column].quantile(0.75)\n",
    "    IQR=Q3-Q1\n",
    "    lower=Q1-1.5*IQR\n",
    "    upper=Q3+1.5*IQR\n",
    "    data[column]=np.where(data[column]<lower,lower,data[column])\n",
    "    data[column]=np.where(data[column]>upper,upper,data[column])\n",
    "    return data"
   ]
  },
